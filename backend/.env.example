# ── Emerald AI — Backend Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env — only .env.example lives in git.

# ── Core ──────────────────────────────────────────────────────────────────────
PORT=3001
ALLOWED_ORIGIN=http://localhost:5173

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ── Media / Search (Serper) ───────────────────────────────────────────────────
SERPER_API_KEY=REPLACE_ME

# ── LLM Visibility APIs ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-REPLACE_ME
PERPLEXITY_API_KEY=pplx-REPLACE_ME
GEMINI_API_KEY=AIzaSy-REPLACE_ME

# ── YouTube OAuth2 ────────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-REPLACE_ME
YOUTUBE_REDIRECT_URI=http://localhost:3001/youtube/callback
